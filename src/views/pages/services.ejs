<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>

    <main>
        <section class="page-header">
            <div class="container">
                <h1>Our Services</h1>
                <p>One philosophy, meeting people in five different rooms of the same house.</p>
            </div>
        </section>

        <div class="services-showcase">
            <!-- SCHOOLS — THE AWAKENING -->
            <section class="service-hero" id="schools">
                <div class="service-hero-image">
                    <img src="https://kimi-web-img.moonshot.cn/img/thumbs.dreamstime.com/accda230994bf6283e8a55b5b794923e3c645da3.jpg" alt="Students in classroom">
                </div>
                <div class="service-hero-overlay"></div>
                <div class="service-hero-content">
                    <span class="service-hero-tag">Schools</span>
                    <h3>The Awakening</h3>
                    <div class="service-hero-price">From E4,500</div>
                    <p>Inspiring students to move from pressure to presence, from performance to self-recognition. A transformative session for young minds ready to see themselves clearly.</p>
                    <div class="service-hero-details">
                        <div class="detail-item">
                            <h4>The Awakening</h4>
                            <div class="price">E4,500</div>
                            <p>3-hour session</p>
                        </div>
                        <div class="detail-item">
                            <h4>The Journey</h4>
                            <div class="price">E10,000</div>
                            <p>3 visits/year</p>
                        </div>
                        <div class="detail-item">
                            <h4>The Prefect's Path</h4>
                            <div class="price">E8,000</div>
                            <p>4-hour leadership</p>
                        </div>
                        <div class="detail-item">
                            <h4>The Full Cup</h4>
                            <div class="price">E5,000</div>
                            <p>Teacher wellness</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CORPORATE — THE BOND -->
            <section class="service-hero" id="corporate">
                <div class="service-hero-image">
                    <img src="https://kimi-web-img.moonshot.cn/img/thumbs.dreamstime.com/c909de380544332a314b16caf6016ce46ec54c9f.jpg" alt="Corporate team">
                </div>
                <div class="service-hero-overlay"></div>
                <div class="service-hero-content">
                    <span class="service-hero-tag">Corporate</span>
                    <h3>The Bond</h3>
                    <div class="service-hero-price">From E15,000</div>
                    <p>Transforming teams through presence, self-knowledge, and the bond of perfection. For organisations that understand culture is built one person at a time.</p>
                    <div class="service-hero-details">
                        <div class="detail-item">
                            <h4>The Bond</h4>
                            <div class="price">E15,000</div>
                            <p>Programme only</p>
                        </div>
                        <div class="detail-item">
                            <h4>Complete Bond</h4>
                            <div class="price">E40,000</div>
                            <p>Full package</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ACCELERATION PROGRAMME -->
            <section class="service-hero" id="acceleration">
                <div class="service-hero-image">
                    <img src="https://kimi-web-img.moonshot.cn/img/img.magnific.com/65be08954e07f8cdda2f039b656100c330dc481b.jpg" alt="Graduates celebrating">
                </div>
                <div class="service-hero-overlay"></div>
                <div class="service-hero-content">
                    <span class="service-hero-tag">Acceleration</span>
                    <h3>Acceleration Programme</h3>
                    <div class="service-hero-price">E6,000 — E8,500</div>
                    <p>Preparing for life beyond school with presence, purpose, and practical wisdom. Three programmes for three thresholds of young adulthood.</p>
                    <div class="service-hero-details">
                        <div class="detail-item">
                            <h4>The Emergence</h4>
                            <div class="price">E6,000</div>
                            <p>High school pupils</p>
                        </div>
                        <div class="detail-item">
                            <h4>The Threshold</h4>
                            <div class="price">E7,500</div>
                            <p>School leavers</p>
                        </div>
                        <div class="detail-item">
                            <h4>The Forge</h4>
                            <div class="price">E8,500</div>
                            <p>Graduates</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PULSE POINTS -->
            <section class="service-hero">
                <div class="service-hero-image">
                    <img src="https://kimi-web-img.moonshot.cn/img/ugbs.ug.edu.gh/972571cd4d817ebbb7fa2f19925899d5ca25ab03.jpeg" alt="University lecture hall">
                </div>
                <div class="service-hero-overlay"></div>
                <div class="service-hero-content">
                    <span class="service-hero-tag">Pulse Points</span>
                    <h3>Evening Engagements</h3>
                    <div class="service-hero-price">E3,500</div>
                    <p>Evening sessions designed for university students and young professionals. Shorter, more intimate, and deeply personal. A pulse of presence in the rhythm of academic life.</p>
                </div>
            </section>

            <!-- THE POET -->
            <section class="service-hero" style="background: linear-gradient(135deg, #1a0a2e 0%, #2a1540 100%);">
                <div class="service-hero-image">
                    <img src="https://kimi-web-img.moonshot.cn/img/media.africasacountry.com/eeb69309fd7ab5a9305bef0874777864aad96c25.jpg" alt="Poet performing">
                </div>
                <div class="service-hero-overlay"></div>
                <div class="service-hero-content">
                    <span class="service-hero-tag">The Poet</span>
                    <h3>Words That Open</h3>
                    <div class="service-hero-price">Included in all sessions</div>
                    <p>The poet is included in every Mindset.i engagement at no extra charge. His words do not explain. They open. His performances are woven into every session, creating moments that stay with people long after the day ends.</p>
                    <div class="service-hero-details">
                        <div class="detail-item">
                            <h4>Private Events</h4>
                            <div class="price">E5,000</div>
                            <p>Weddings, dinners, specials</p>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>